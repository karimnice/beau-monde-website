---
// Renders a single page-level dialog with Call + Text options.
// Wire any anchor on the page to open it by adding `data-tour-trigger="<label>"`.
// `<label>` is a free-form string; use a suite name (e.g. "Suite 4") to pre-fill
// the SMS body with context, or "general" for a plain prompt.
---

<dialog
  id="contact-dialog"
  class="w-[92vw] max-w-sm rounded-lg bg-white p-0 shadow-xl backdrop:bg-charcoal/60 backdrop:backdrop-blur-sm"
>
  <div class="relative p-7 text-center">
    <button
      type="button"
      id="contact-dialog-close"
      aria-label="Close"
      class="absolute top-3 right-3 flex h-8 w-8 items-center justify-center rounded-full text-muted transition-colors hover:bg-gray-100 hover:text-charcoal"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <p class="font-heading text-xs font-semibold tracking-[0.18em] uppercase text-gold">
      Schedule a Tour
    </p>
    <h3 class="mt-2 font-heading text-xl font-bold text-charcoal" id="contact-dialog-heading">
      How would you like to reach us?
    </h3>
    <p class="mt-2 text-sm text-muted">
      We'll get back to you to set a time.
    </p>

    <div class="mt-6 grid gap-3">
      <a
        id="contact-dialog-call"
        href="tel:+19195518406"
        class="flex items-center justify-center gap-2 rounded-sm bg-gold px-6 py-3 text-sm font-semibold tracking-wide uppercase text-white transition-colors hover:bg-gold-dark"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h2.6a1 1 0 01.95.68l1.2 3.6a1 1 0 01-.27 1.06l-1.7 1.7a13 13 0 006.18 6.18l1.7-1.7a1 1 0 011.06-.27l3.6 1.2a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.82 21 3 14.18 3 6V5z" />
        </svg>
        Call (919) 551-8406
      </a>
      <a
        id="contact-dialog-text"
        href="sms:+19195518406"
        class="flex items-center justify-center gap-2 rounded-sm border-2 border-gold px-6 py-3 text-sm font-semibold tracking-wide uppercase text-gold transition-colors hover:bg-gold hover:text-white"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12a8 8 0 01-11.2 7.3L3 21l1.7-6.8A8 8 0 1121 12z" />
        </svg>
        Text (919) 551-8406
      </a>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById("contact-dialog") as HTMLDialogElement | null;
  const heading = document.getElementById("contact-dialog-heading");
  const textLink = document.getElementById("contact-dialog-text") as HTMLAnchorElement | null;
  const closeBtn = document.getElementById("contact-dialog-close");

  const triggers = document.querySelectorAll<HTMLAnchorElement>("[data-tour-trigger]");

  const openDialog = (label: string) => {
    if (!dialog) return;
    if (heading) {
      heading.textContent =
        label === "general"
          ? "How would you like to reach us?"
          : `Tour ${label} — how would you like to reach us?`;
    }
    if (textLink) {
      textLink.href =
        label === "general"
          ? "sms:+19195518406"
          : `sms:+19195518406?&body=${encodeURIComponent(`Hi! I'd like to schedule a tour of ${label} at Beau Monde.`)}`;
    }
    dialog.showModal();
  };

  triggers.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      openDialog(btn.dataset.tourTrigger ?? "general");
    });
  });

  closeBtn?.addEventListener("click", () => dialog?.close());

  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
