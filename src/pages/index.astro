---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ProfessionalCard from "../components/ProfessionalCard.astro";
import { getCollection } from "astro:content";
import heroLogo from "../assets/logo/logo-hero.png";
import heroBg from "../assets/hero/hero-bg.jpg";

const professionals = (await getCollection("professionals")).sort(
  (a, b) => a.data.order - b.data.order
);

const categories = [
  { value: "all", label: "All" },
  { value: "hair", label: "Hair" },
  { value: "nails", label: "Nails" },
  { value: "skincare", label: "Skin Care" },
  { value: "brows-lashes", label: "Brows & Lashes" },
];
---

<Layout>
  <section class="relative overflow-hidden bg-cream py-10 md:py-14">
    <Image
      src={heroBg}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      widths={[800, 1600]}
    />
    <div class="absolute inset-0 bg-cream/60"></div>
    <div class="relative mx-auto max-w-2xl px-6 text-center">
      <Image
        src={heroLogo}
        alt="Beau Monde Salon Suites"
        class="mx-auto w-full max-w-md"
        widths={[400, 800]}
      />
      <p class="mt-4 text-sm tracking-wide uppercase text-muted">
        <a
          href="https://share.google/yXlE68tAXU6lEkBh8"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-gold"
        >
          Holly Springs, NC at The Block on Main
        </a>
      </p>
      <p class="mt-2 text-lg text-muted">
        Meet the talented beauty professionals who call Beau Monde home.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    {/* Category filter */}
    <div class="mb-10 flex flex-wrap justify-center gap-2" id="filter-bar">
      {categories.map((cat) => (
        <button
          data-filter={cat.value}
          class:list={[
            "rounded-full px-5 py-2 text-sm font-medium transition-colors",
            cat.value === "all"
              ? "bg-gold text-white"
              : "bg-gray-100 text-muted hover:bg-gray-200",
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Grid */}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="professionals-grid">
      {professionals.map((pro) => (
        <ProfessionalCard
          name={pro.data.name}
          title={pro.data.title}
          slug={pro.id}
          category={pro.data.category}
          photo={pro.data.photo}
          suite={pro.data.suite}
        />
      ))}
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("#filter-bar button");
  const cards = document.querySelectorAll<HTMLElement>("#professionals-grid > a");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove("bg-gold", "text-white");
        b.classList.add("bg-gray-100", "text-muted");
      });
      btn.classList.remove("bg-gray-100", "text-muted");
      btn.classList.add("bg-gold", "text-white");

      cards.forEach((card) => {
        if (filter === "all" || card.dataset.category === filter) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>
