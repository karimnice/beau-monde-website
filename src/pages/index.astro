---
import Layout from "../layouts/Layout.astro";
import ProfessionalCard from "../components/ProfessionalCard.astro";
import { getCollection } from "astro:content";

const professionals = (await getCollection("professionals")).sort(
  (a, b) => a.data.order - b.data.order
);

const categories = [
  { value: "all", label: "All" },
  { value: "hair", label: "Hair" },
  { value: "nails", label: "Nails" },
  { value: "skincare", label: "Skin Care" },
  { value: "brows-lashes", label: "Brows & Lashes" },
];
---

<Layout>
  <section class="bg-cream py-16">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="font-heading text-sm font-semibold tracking-[0.2em] uppercase text-gold">
        Holly Springs, NC
      </p>
      <h1 class="mt-3 font-heading text-4xl font-bold text-charcoal md:text-5xl">
        Salon Professionals
      </h1>
      <p class="mt-4 text-lg text-muted">
        Meet the talented beauty professionals who call Beau Monde home.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    {/* Category filter */}
    <div class="mb-10 flex flex-wrap justify-center gap-2" id="filter-bar">
      {categories.map((cat) => (
        <button
          data-filter={cat.value}
          class:list={[
            "rounded-full px-5 py-2 text-sm font-medium transition-colors",
            cat.value === "all"
              ? "bg-gold text-white"
              : "bg-gray-100 text-muted hover:bg-gray-200",
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Grid */}
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="professionals-grid">
      {professionals.map((pro) => (
        <ProfessionalCard
          name={pro.data.name}
          title={pro.data.title}
          slug={pro.id}
          category={pro.data.category}
          photo={pro.data.photo}
        />
      ))}
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>("#filter-bar button");
  const cards = document.querySelectorAll<HTMLElement>("#professionals-grid > a");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove("bg-gold", "text-white");
        b.classList.add("bg-gray-100", "text-muted");
      });
      btn.classList.remove("bg-gray-100", "text-muted");
      btn.classList.add("bg-gold", "text-white");

      cards.forEach((card) => {
        if (filter === "all" || card.dataset.category === filter) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>
