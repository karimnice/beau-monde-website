---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Privacy Policy | Beau Monde Salon Suites" description="Privacy policy for the Beau Monde Salon Suites website.">
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="font-heading text-3xl font-bold text-charcoal">Privacy Policy</h1>
      <p class="mt-2 text-sm text-muted">Last updated: March 4, 2026</p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-muted">
        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Information We Collect</h2>
          <p class="mt-2">
            This website does not collect, store, or process any personal information from visitors. We do not use contact forms, account registrations, or analytics tracking on this site.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Cookies</h2>
          <p class="mt-2">
            This website does not use cookies or any similar tracking technologies. However, third-party websites we link to — including booking platforms, Google Forms, Instagram, and Facebook — may use their own cookies and tracking technologies. We encourage you to review the privacy policies of those services before providing any information.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Third-Party Links</h2>
          <p class="mt-2">
            Our site contains links to external websites and services, including:
          </p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <li>Online booking platforms used by our professionals</li>
            <li>A Google Forms waitlist for leasing inquiries</li>
            <li>Social media profiles on Instagram and Facebook</li>
          </ul>
          <p class="mt-2">
            These third-party sites operate independently and have their own privacy policies. We are not responsible for the content or privacy practices of these external sites. Any information you provide to those services is governed by their respective privacy policies.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Professional Contact Information</h2>
          <p class="mt-2">
            This site displays publicly available contact information for our salon professionals, such as email addresses and phone numbers, to help clients reach them directly. This information is provided by the professionals themselves and is not collected from visitors.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Changes to This Policy</h2>
          <p class="mt-2">
            We may update this privacy policy from time to time. Any changes will be reflected on this page with an updated date.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-lg font-semibold text-charcoal">Contact</h2>
          <p class="mt-2">
            If you have questions about this privacy policy, please contact us at
            <a href="tel:+19195518406" class="text-gold transition-colors hover:text-gold-dark">(919) 551-8406</a>
            or visit us at 300 S Main St, Holly Springs, NC 27540.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
