---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import heroBg from "../../assets/hero/hero-bg.jpg";
import salonPhoto from "../../assets/salon/salon-2.jpg";
---

<Layout title="About & Leasing | Beau Monde Salon Suites">
  {/* Hero */}
  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden">
    <Image src={heroBg} alt="" class="absolute inset-0 h-full w-full object-cover" widths={[800, 1200, 1920]} />
    <div class="absolute inset-0 bg-charcoal/50"></div>
    <div class="relative mx-auto max-w-3xl px-6 py-24 text-center">
      <p class="font-heading text-sm font-semibold tracking-[0.2em] uppercase text-gold">
        Holly Springs, NC
      </p>
      <h1 class="mt-4 font-heading text-4xl font-bold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl">
        Locally-Owned Luxury Salon Suites
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-gray-200">
        The first boutique salon suite concept in Holly Springs. Bright, airy
        suites home to the area's top beauty professionals.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <Button href="/">Meet Our Professionals</Button>
        <Button href="tel:+19195518406" variant="outline">Call Us</Button>
      </div>
    </div>
  </section>

  {/* About */}
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <div>
        <p class="font-heading text-sm font-semibold tracking-[0.2em] uppercase text-gold">
          About Us
        </p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-charcoal">
          A Beautiful Space for Beautiful Work
        </h2>
        <p class="mt-4 leading-relaxed text-muted">
          Opened in August 2021, Beau Monde Salon Suites is a locally owned
          boutique salon suite concept — the first of its kind in Holly Springs.
          Located in The Block on Main in Downtown Holly Springs, we feature 8
          single and 5 double bright and airy suites with plenty of windows and
          abundant natural light.
        </p>
        <p class="mt-4 leading-relaxed text-muted">
          Each suite is home to amazing stylists, aestheticians, brow
          specialists, nail artists, and aesthetic medical practitioners.
        </p>
      </div>
      <Image src={salonPhoto} alt="Beau Monde Salon Suites interior" class="rounded-lg object-cover aspect-[4/3]" widths={[400, 800]} />
    </div>
  </section>

  {/* Services */}
  <section class="bg-cream py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <p class="font-heading text-sm font-semibold tracking-[0.2em] uppercase text-gold">
          Our Services
        </p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-charcoal">
          Find Your Perfect Professional
        </h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: "Hair", description: "Cuts, color, extensions, styling, and more from expert hair stylists." },
          { title: "Nails", description: "Manicures, pedicures, nail art, and luxury nail care services." },
          { title: "Skin Care", description: "Facials, peels, and advanced skincare treatments for radiant skin." },
          { title: "Waxing, Brows & Lashes", description: "Expert waxing, brow shaping, and lash extensions." },
        ].map((service) => (
          <div class="rounded-lg bg-white p-8 text-center shadow-sm transition-shadow hover:shadow-md">
            <h3 class="font-heading text-lg font-semibold text-charcoal">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Testimonial */}
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <svg class="mx-auto h-10 w-10 text-gold/30" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
      </svg>
      <blockquote class="mt-6 text-xl leading-relaxed text-charcoal italic">
        "One stylist couldn't fit me in on short notice, but found another
        stylist that could. WOW! Gotta love women supporting women! I came
        out with a fabulous haircut and a new salon."
      </blockquote>
      <p class="mt-4 text-sm font-medium text-muted">— Happy Client</p>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="font-heading text-sm font-semibold tracking-[0.2em] uppercase text-gold">
        For Professionals
      </p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-white">
        Join the Beau Monde Collection
      </h2>
      <p class="mt-4 leading-relaxed text-gray-400">
        Be your own boss. Set your own hours and rates, sell the products of
        your choice, and keep 100% of your profits — all in a beautiful,
        professionally maintained space.
      </p>
      <div class="mt-8">
        <Button href="tel:+19195518406" variant="outline">
          Inquire About a Suite
        </Button>
      </div>
    </div>
  </section>
</Layout>
