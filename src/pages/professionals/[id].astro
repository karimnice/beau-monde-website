---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const professionals = await getCollection("professionals");
  const sorted = professionals.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((pro, i) => ({
    params: { id: pro.id },
    props: {
      professional: pro,
      prev: i > 0 ? { id: sorted[i - 1].id, name: sorted[i - 1].data.name } : null,
      next: i < sorted.length - 1 ? { id: sorted[i + 1].id, name: sorted[i + 1].data.name } : null,
    },
  }));
}

const { professional, prev, next } = Astro.props;
const { data } = professional;
const { Content } = await render(professional);

const categoryLabels: Record<string, string> = {
  hair: "Hair",
  nails: "Nails",
  skincare: "Skin Care",
  "brows-lashes": "Brows & Lashes",
};

---

<Layout title={`${data.name} | Beau Monde Salon Suites`}>
  <section class="bg-cream py-16">
    <div class="mx-auto max-w-4xl px-6">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm text-muted transition-colors hover:text-gold"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-2">
      {/* Photo */}
      <div class="relative">
        {data.photo ? (
          <Image
            src={data.photo}
            alt={data.name}
            class="aspect-square w-full rounded-lg object-cover"
            widths={[400, 800]}
          />
        ) : (
          <div class="flex aspect-square items-center justify-center rounded-lg bg-gradient-to-br from-cream to-gray-100">
            <span class="font-heading text-6xl font-bold text-gold/20">
              {data.name.charAt(0)}
            </span>
          </div>
        )}
        {data.suite && (
          <span class="absolute top-4 left-4 rounded-sm bg-charcoal/80 px-3 py-1.5 text-sm font-semibold text-white backdrop-blur-sm">
            {data.suite}
          </span>
        )}
      </div>

      {/* Info */}
      <div>
        <span class="inline-block rounded-full bg-gold/10 px-3 py-1 text-xs font-medium text-gold">
          {categoryLabels[data.category]}
        </span>
        <h1 class="mt-4 font-heading text-3xl font-bold text-charcoal md:text-4xl">
          {data.name}
        </h1>
        <p class="mt-1 text-lg text-muted">{data.title}</p>
        <p class="mt-6 leading-relaxed text-muted">{data.bio}</p>

        {data.services && data.services.length > 0 && (
          <div class="mt-8">
            <h3 class="font-heading text-sm font-semibold tracking-wide uppercase text-charcoal">
              Services
            </h3>
            <ul class="mt-3 flex flex-wrap gap-2">
              {data.services.map((service) => (
                <li class="rounded-full border border-gray-200 px-3 py-1 text-sm text-muted">
                  {service}
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Actions */}
        <div class="mt-8 flex flex-wrap gap-3">
          {data.bookingUrl && (
            <Button href={data.bookingUrl} target="_blank" rel="noopener noreferrer">Book Now</Button>
          )}
          {data.phone && (
            <Button href={`tel:${data.phone}`} variant="outline">Call</Button>
          )}
          {data.email && (
            <Button href={`mailto:${data.email}`} variant="outline">Email</Button>
          )}
          {data.instagram && (
            <a
              href={data.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-sm border-2 border-gray-200 px-4 py-3 text-sm font-medium text-muted transition-colors hover:border-gold hover:text-gold"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
              </svg>
              Instagram
            </a>
          )}
          {data.facebook && (
            <a
              href={data.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-sm border-2 border-gray-200 px-4 py-3 text-sm font-medium text-muted transition-colors hover:border-gold hover:text-gold"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              Facebook
            </a>
          )}
        </div>

        {/* Markdown content if any */}
        <div class="prose mt-8">
          <Content />
        </div>
      </div>
    </div>
  </section>

  {/* Prev / Next Navigation */}
  {(prev || next) && (
    <nav class="border-t border-gray-200 bg-cream">
      <div class="mx-auto flex max-w-4xl items-stretch">
        {prev ? (
          <a
            href={`/professionals/${prev.id}`}
            class="group flex flex-1 items-center gap-2 px-6 py-6 text-muted transition-colors hover:text-gold"
          >
            <svg class="h-4 w-4 shrink-0 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span class="text-sm font-medium">{prev.name}</span>
          </a>
        ) : <div class="flex-1" />}
        {next ? (
          <a
            href={`/professionals/${next.id}`}
            class="group flex flex-1 items-center justify-end gap-2 px-6 py-6 text-muted transition-colors hover:text-gold"
          >
            <span class="text-sm font-medium">{next.name}</span>
            <svg class="h-4 w-4 shrink-0 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <div class="flex-1" />}
      </div>
    </nav>
  )}

</Layout>
